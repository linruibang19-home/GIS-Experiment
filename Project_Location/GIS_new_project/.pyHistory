import pandas as pd import numpy as np  # ===== 1. 输入文件路径 ===== input_csv = r"D:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\1、创建渔网\grid_base_500m_for_dl.csv" output_csv = r"D:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\1、创建渔网\grid_base_500m_with_dl_id.csv"  # ===== 2. 读取数据 ===== df = pd.read_csv(input_csv, encoding="utf-8")  # ===== 3. 检查字段名 ===== print("字段名：", df.columns.tolist())  # 如果你的字段名不是这些，请在这里改 x_col = "cent_x" y_col = "cent_y" gridid_col = "grid_id"  # ===== 4. 设置格网大小 ===== cell_size = 500  # ===== 5. 计算行列号 ===== xmin = df[x_col].min() ymax = df[y_col].max()  df["col_id"] = ((df[x_col] - xmin) / cell_size).round().astype(int) + 1 df["row_id"] = ((ymax - df[y_col]) / cell_size).round().astype(int) + 1  # ===== 6. 生成深度学习专用格网ID ===== row_width = max(3, len(str(df["row_id"].max()))) col_width = max(3, len(str(df["col_id"].max())))  df["dl_grid_id"] = (     "R" + df["row_id"].astype(str).str.zfill(row_width) +     "C" + df["col_id"].astype(str).str.zfill(col_width) )  # ===== 7. 检查是否有重复的行列组合 ===== dup_check = df.duplicated(subset=["row_id", "col_id"]).sum() print("重复的 row_id + col_id 数量：", dup_check)  if dup_check > 0:     print("警告：存在重复的行列组合，请检查 cent_x/cent_y 或格网是否规则。") else:     print("row_id + col_id 唯一，可用于深度学习矩阵重建。")  # ===== 8. 输出结果 ===== df.to_csv(output_csv, index=False, encoding="utf-8-sig") print("已输出：", output_csv)  # ===== 9. 显示基础信息 ===== print("总格网数：", len(df)) print("最大行号：", df["row_id"].max()) print("最大列号：", df["col_id"].max())
import pandas as pd  # ========================= # 1. 输入输出路径 # ========================= grid_csv = r"D:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\4、格网点年度汇总统计\clip格网ID表.csv" stat_csv = r"D:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\4、格网点年度汇总统计\非完整格网年份汇总表.csv"  output_csv = r"D:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\4、格网点年度汇总统计\grid_year_panel_complete_clip.csv"  # ========================= # 2. 读取数据 # ========================= grid_df = pd.read_csv(grid_csv, encoding="utf-8") stat_df = pd.read_csv(stat_csv, encoding="utf-8")  print("clip格网ID表字段：", grid_df.columns.tolist()) print("非完整格网年份汇总表字段：", stat_df.columns.tolist())  # ========================= # 3. 提取唯一 grid_id # ========================= grid_df = grid_df[["grid_id"]].drop_duplicates().copy() grid_df = grid_df[grid_df["grid_id"].notna()].copy()  print("有效格网数量：", len(grid_df))  # ========================= # 4. 构造年份表（2015-2024） # ========================= years = pd.DataFrame({"year": list(range(2015, 2025))})  # ========================= # 5. 做 grid_id × year 笛卡尔积 # ========================= grid_df["key"] = 1 years["key"] = 1  panel_base = pd.merge(grid_df, years, on="key").drop(columns="key")  print("完整骨架表行数：", len(panel_base)) print(panel_base.head())  # ========================= # 6. 统计表保留需要字段 # ========================= stat_keep_cols = [     "grid_id",     "year",     "FREQUENCY",     "active_cnt",     "entry_cnt",     "persist_cnt",     "renew_proxy_cnt",     "exit_next_cnt" ]  stat_df = stat_df[stat_keep_cols].copy()  # 年份转整数 stat_df["year"] = stat_df["year"].astype(int)  # ========================= # 7. 合并统计值 # ========================= panel_complete = pd.merge(     panel_base,     stat_df,     on=["grid_id", "year"],     how="left" )  # ========================= # 8. 空值补 0 # ========================= fill_cols = [     "FREQUENCY",     "active_cnt",     "entry_cnt",     "persist_cnt",     "renew_proxy_cnt",     "exit_next_cnt" ]  panel_complete[fill_cols] = panel_complete[fill_cols].fillna(0)  for col in fill_cols:     panel_complete[col] = panel_complete[col].astype(int)  # ========================= # 9. 排序 # ========================= panel_complete = panel_complete.sort_values(     by=["grid_id", "year"] ).reset_index(drop=True)  # ========================= # 10. 逻辑检查 # active_cnt = entry_cnt + persist_cnt # ========================= panel_complete["check_active"] = panel_complete["entry_cnt"] + panel_complete["persist_cnt"] panel_complete["active_check_ok"] = panel_complete["active_cnt"] == panel_complete["check_active"]  bad_rows = panel_complete[panel_complete["active_check_ok"] == False] print("不满足 active_cnt = entry_cnt + persist_cnt 的记录数：", len(bad_rows))  # 如果你不想保留检查列，可以删除 panel_complete = panel_complete.drop(columns=["check_active", "active_check_ok"])  # ========================= # 11. 输出 # ========================= panel_complete.to_csv(output_csv, index=False, encoding="utf-8-sig")  print("输出完成：", output_csv) print("最终完整面板总行数：", len(panel_complete)) print(panel_complete.head(20))
# -*- coding: utf-8 -*- """ 批量将每年格网面板数据连接到 grid_base_clip 并导出为独立要素类  使用方法：在 ArcGIS Pro 的 Python 窗口中逐段粘贴运行，或整体粘贴运行 """  import arcpy import os  # ═══════════════════════════════════════════════════════════════ # 路径配置 # ═══════════════════════════════════════════════════════════════  # grid_base_clip 所在的地理数据库 GRID_GDB = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\1、创建渔网\Fishnet for spaceReaserch.gdb" GRID_FC  = os.path.join(GRID_GDB, "grid_base_clip")  # 年度 CSV 所在文件夹 CSV_DIR = r"d:\研究生\论文\高新技术企业空间集聚\原数据\高新技术企业数据库\数据处理\output\核心数据\06_格网年度面板\yearly"  # 输出地理数据库（自动创建） OUTPUT_GDB = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\5、格网数据最终版\格网年度面板.gdb"  # ═══════════════════════════════════════════════════════════════ # 执行 # ═══════════════════════════════════════════════════════════════  # 1. 创建输出 GDB（如果不存在） if not arcpy.Exists(OUTPUT_GDB):     gdb_folder = os.path.dirname(OUTPUT_GDB)     gdb_name   = os.path.basename(OUTPUT_GDB)     if not os.path.exists(gdb_folder):         os.makedirs(gdb_folder)     arcpy.management.CreateFileGDB(gdb_folder, gdb_name)     print(f"[创建] {OUTPUT_GDB}")  # 2. 逐年连接并导出 for year in range(2015, 2025):     csv_path = os.path.join(CSV_DIR, f"grid_panel_{year}.csv")      if not os.path.exists(csv_path):         print(f"[跳过] {year}: CSV 不存在")         continue      layer_name = f"grid_layer_{year}"     table_name = f"panel_table_{year}"     output_fc  = os.path.join(OUTPUT_GDB, f"grid_panel_{year}")      # 如果输出已存在，跳过     if arcpy.Exists(output_fc):         print(f"[跳过] {year}: 输出已存在")         continue      # 创建临时要素图层     arcpy.management.MakeFeatureLayer(GRID_FC, layer_name)      # 将 CSV 加载为临时表视图     arcpy.management.MakeTableView(csv_path, table_name)      # 添加连接（grid_id ? grid_id）     arcpy.management.AddJoin(layer_name, "grid_id", table_name, "grid_id", "KEEP_ALL")      # 导出为新要素类     arcpy.management.CopyFeatures(layer_name, output_fc)      # 移除连接并清理     arcpy.management.RemoveJoin(layer_name)     arcpy.management.Delete(layer_name)     arcpy.management.Delete(table_name)      print(f"[完成] {year} → {os.path.basename(output_fc)}")  print("\n=== 全部完成 ===") print(f"输出位置: {OUTPUT_GDB}")
# -*- coding: utf-8 -*- """ 批量清理格网年度要素类中 Join 产生的重复字段  使用方法：在 ArcGIS Pro 的 Python 窗口中运行 """  import arcpy import os  # ═══════════════════════════════════════════════════════════════ # 路径配置 # ═══════════════════════════════════════════════════════════════ OUTPUT_GDB = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\5、格网数据最终版\格网年度面板.gdb"  # Join 产生的重复字段（来自 CSV 表的 grid_id、centroid_x、centroid_y） # ArcGIS 会给它们加上 CSV 表名前缀，可能的命名模式如下 DUPLICATE_PATTERNS = [     "grid_panel_",   # 如 grid_panel_2024_grid_id     "centroid_x_1",  # 有时 ArcGIS 直接加 _1 后缀     "centroid_y_1",     "grid_id_1", ]  # ═══════════════════════════════════════════════════════════════ # 执行 # ═══════════════════════════════════════════════════════════════ for year in range(2015, 2025):     fc = os.path.join(OUTPUT_GDB, f"grid_panel_{year}")      if not arcpy.Exists(fc):         print(f"[跳过] {year}: 要素类不存在")         continue      # 获取所有字段名（排除系统字段）     fields = [f.name for f in arcpy.ListFields(fc)               if f.name not in ("OBJECTID", "Shape", "Shape_Length", "Shape_Area", "OID")]      # 需要保留的核心字段（来自格网底图）     keep_fields = {"grid_id", "centroid_x", "centroid_y"}      # 找出需要删除的重复字段     to_delete = []     for f in fields:         # 跳过需要保留的核心字段         if f in keep_fields:             continue         # 检查是否是重复的 grid_id / centroid_x / centroid_y         f_lower = f.lower()         if any(kw in f_lower for kw in ["grid_id", "centroid_x", "centroid_y"]):             to_delete.append(f)      if to_delete:         arcpy.management.DeleteField(fc, to_delete)         print(f"[{year}] 删除 {len(to_delete)} 个重复字段: {to_delete}")     else:         print(f"[{year}] 无重复字段")  print("\n=== 清理完成 ===")
# -*- coding: utf-8 -*- """ 批量将每年格网面板数据连接到 grid_base_clip 并导出为独立要素类 导出后自动清理 Join 产生的重复字段（保留格网底图的，删除 CSV 带来的）  使用方法：在 ArcGIS Pro 的 Python 窗口中运行 """  import arcpy import os  # ═══════════════════════════════════════════════════════════════ # 路径配置 # ═══════════════════════════════════════════════════════════════  # grid_base_clip 所在的地理数据库 GRID_GDB = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\1、创建渔网\Fishnet for spaceReaserch.gdb" GRID_FC  = os.path.join(GRID_GDB, "grid_base_clip")  # 年度 CSV 所在文件夹 CSV_DIR = r"d:\研究生\论文\高新技术企业空间集聚\原数据\高新技术企业数据库\数据处理\output\核心数据\06_格网年度面板\yearly"  # 输出地理数据库（自动创建） OUTPUT_GDB = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\5、格网数据最终版\格网年度面板.gdb"  # 格网底图自带的字段（这些是要保留的「正版」） GRID_BASE_FIELDS = {"OBJECTID", "Shape", "grid_id", "centroid_x", "centroid_y",                     "Shape_Length", "Shape_Area"}  # ═══════════════════════════════════════════════════════════════ # 执行 # ═══════════════════════════════════════════════════════════════  # 1. 创建输出 GDB（如果不存在） if not arcpy.Exists(OUTPUT_GDB):     gdb_folder = os.path.dirname(OUTPUT_GDB)     gdb_name   = os.path.basename(OUTPUT_GDB)     if not os.path.exists(gdb_folder):         os.makedirs(gdb_folder)     arcpy.management.CreateFileGDB(gdb_folder, gdb_name)     print(f"[创建] {OUTPUT_GDB}")  # 2. 逐年：删除旧的 → 重新 Join 导出 → 清理重复字段 for year in range(2015, 2025):     csv_path = os.path.join(CSV_DIR, f"grid_panel_{year}.csv")      if not os.path.exists(csv_path):         print(f"[跳过] {year}: CSV 不存在")         continue      layer_name = f"grid_layer_{year}"     table_name = f"panel_table_{year}"     output_fc  = os.path.join(OUTPUT_GDB, f"grid_panel_{year}")      # 如果输出已存在，先删除重新生成     if arcpy.Exists(output_fc):         arcpy.management.Delete(output_fc)      # ── Join 并导出 ─────────────────────────────────────────     arcpy.management.MakeFeatureLayer(GRID_FC, layer_name)     arcpy.management.MakeTableView(csv_path, table_name)     arcpy.management.AddJoin(layer_name, "grid_id", table_name, "grid_id", "KEEP_ALL")     arcpy.management.CopyFeatures(layer_name, output_fc)     arcpy.management.RemoveJoin(layer_name)     arcpy.management.Delete(layer_name)     arcpy.management.Delete(table_name)      # ── 清理重复字段 ───────────────────────────────────────     # Join 导出后，CSV 的 grid_id/centroid_x/centroid_y 会变成带后缀的字段     # 例如：grid_id_1, centroid_x_1, centroid_y_1     # 或带表名前缀：grid_panel_2024_grid_id 等     # 策略：只保留格网底图的原始字段，删除所有含 grid_id/centroid 关键词的「额外」字段     all_fields = [f.name for f in arcpy.ListFields(output_fc)]     to_delete = []     for f in all_fields:         if f in GRID_BASE_FIELDS:             continue  # 保留底图原始字段         f_lower = f.lower()         if any(kw in f_lower for kw in ["grid_id", "centroid_x", "centroid_y", "oid_"]):             to_delete.append(f)      if to_delete:         arcpy.management.DeleteField(output_fc, to_delete)      # 输出最终字段列表     final_fields = [f.name for f in arcpy.ListFields(output_fc)                     if f.name not in ("OBJECTID", "Shape")]     print(f"[{year}] 完成 | 删除重复: {to_delete} | 剩余 {len(final_fields)} 个字段")  print(f"\n=== 全部完成 ===") print(f"输出位置: {OUTPUT_GDB}")
# -*- coding: utf-8 -*- """ 批量将每年格网面板数据连接到 grid_base_clip 并导出为独立要素类  CSV 中已去除 centroid_x/centroid_y（格网底图自带），Join 后不会产生重复字段  使用方法：   1. 先运行 step9_split_yearly_panels.py 生成新的年度 CSV   2. 再在 ArcGIS Pro 的 Python 窗口中运行本脚本 """  import arcpy import os  # ═══════════════════════════════════════════════════════════════ # 路径配置 # ═══════════════════════════════════════════════════════════════  GRID_GDB = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\1、创建渔网\Fishnet for spaceReaserch.gdb" GRID_FC  = os.path.join(GRID_GDB, "grid_base_clip")  CSV_DIR = r"d:\研究生\论文\高新技术企业空间集聚\原数据\高新技术企业数据库\数据处理\output\核心数据\06_格网年度面板\yearly"  OUTPUT_GDB = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\5、格网数据最终版\格网年度面板.gdb"  # ═══════════════════════════════════════════════════════════════ # 执行 # ═══════════════════════════════════════════════════════════════  # 1. 创建输出 GDB if not arcpy.Exists(OUTPUT_GDB):     gdb_folder = os.path.dirname(OUTPUT_GDB)     gdb_name   = os.path.basename(OUTPUT_GDB)     if not os.path.exists(gdb_folder):         os.makedirs(gdb_folder)     arcpy.management.CreateFileGDB(gdb_folder, gdb_name)     print(f"[创建] {OUTPUT_GDB}")  # 2. 逐年 Join 并导出 for year in range(2015, 2025):     csv_path = os.path.join(CSV_DIR, f"grid_panel_{year}.csv")      if not os.path.exists(csv_path):         print(f"[跳过] {year}: CSV 不存在")         continue      layer_name = f"grid_layer_{year}"     table_name = f"panel_table_{year}"     output_fc  = os.path.join(OUTPUT_GDB, f"grid_panel_{year}")      # 如果输出已存在，先删除     if arcpy.Exists(output_fc):         arcpy.management.Delete(output_fc)      # Join 并导出     arcpy.management.MakeFeatureLayer(GRID_FC, layer_name)     arcpy.management.MakeTableView(csv_path, table_name)     arcpy.management.AddJoin(layer_name, "grid_id", table_name, "grid_id", "KEEP_ALL")     arcpy.management.CopyFeatures(layer_name, output_fc)     arcpy.management.RemoveJoin(layer_name)     arcpy.management.Delete(layer_name)     arcpy.management.Delete(table_name)      # 打印结果     fc_count = int(arcpy.management.GetCount(output_fc)[0])     field_names = [f.name for f in arcpy.ListFields(output_fc)]     print(f"[{year}] {fc_count} 行, {len(field_names)} 个字段: {field_names}")  print(f"\n=== 全部完成 ===") print(f"输出位置: {OUTPUT_GDB}")
# -*- coding: utf-8 -*- """ ArcGIS：构建 clip 格网 -> 主格网（完整规则格网）映射表  设计目标： 1. 不推翻既有成果，不重做前 1-9 步实验 2. 将既有 clip 格网的随机 grid_id 丝滑替换到统一主格网体系 3. 一次性解决两个问题：    - 边界处 clip 后的非完整格网    - 广州市边界外的完整规则格网  核心原则： - 完整规则格网是唯一主格网（master grid） - clip 格网只是主格网在行政边界内的裁剪结果 - 每个 clip 格网都应精确对应到 1 个主格网单元 - 边界格网通过 cover_ratio / boundary_mask 表达，而不是继续保留不规则几何作为主键体系  在 ArcGIS Pro 的 Python 窗口中运行。 """  import arcpy import csv import os from pathlib import Path  arcpy.env.overwriteOutput = True  # ─── 路径配置 ────────────────────────────────────────────────── PROJECT_ROOT = Path(r"d:\研究生\论文\高新技术企业空间集聚\原数据\高新技术企业数据库\数据处理")  CLIP_GDB = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\1、创建渔网\Fishnet for spaceReaserch.gdb" CLIP_FC = os.path.join(CLIP_GDB, "grid_base_clip")  MASTER_GDB = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\1、创建渔网\DL-fishnet500m.gdb" MASTER_FC = os.path.join(MASTER_GDB, "grid_base_500m_dl_ready")  OUTPUT_DIR = PROJECT_ROOT / "output" / "中间数据" MAPPING_CSV = OUTPUT_DIR / "clip_to_master_grid_mapping.csv" MASTER_META_CSV = OUTPUT_DIR / "master_grid_metadata.csv" REPORT_TXT = OUTPUT_DIR / "clip_to_master_grid_mapping_report.txt"  GIS_OUTPUT_FOLDER = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\6、主格网统一" GIS_OUTPUT_GDB = os.path.join(GIS_OUTPUT_FOLDER, "主格网统一.gdb") MAPPING_FC = os.path.join(GIS_OUTPUT_GDB, "clip_master_mapping") TEMP_SJ = r"in_memory\clip_master_spatial_join"  # ─── 工具函数 ────────────────────────────────────────────────── def ensure_output_gdb():     if not os.path.exists(GIS_OUTPUT_FOLDER):         os.makedirs(GIS_OUTPUT_FOLDER)     if not arcpy.Exists(GIS_OUTPUT_GDB):         arcpy.management.CreateFileGDB(GIS_OUTPUT_FOLDER, os.path.basename(GIS_OUTPUT_GDB))   def load_master_info():     """读取主格网元数据，构建 grid_id -> info 字典。"""     master_info = {}     fields = ["dl_grid_id", "row_id", "col_id", "cent_x", "crnt_y", "SHAPE@AREA"]     with arcpy.da.SearchCursor(MASTER_FC, fields) as cursor:         for dl_grid_id, row_id, col_id, cent_x, cent_y, shape_area in cursor:             master_info[dl_grid_id] = {                 "new_grid_id": dl_grid_id,                 "row_id": row_id,                 "col_id": col_id,                 "centroid_x": cent_x,                 "centroid_y": cent_y,                 "master_area": shape_area,             }     return master_info   def export_master_metadata(master_info):     """导出完整主格网元数据（全部格网，不仅仅是广州市内）。"""     fieldnames = [         "grid_id", "row_id", "col_id", "centroid_x", "centroid_y", "master_area"     ]     with open(MASTER_META_CSV, "w", newline="", encoding="utf-8-sig") as f:         writer = csv.DictWriter(f, fieldnames=fieldnames)         writer.writeheader()         for item in master_info.values():             writer.writerow({                 "grid_id": item["new_grid_id"],                 "row_id": item["row_id"],                 "col_id": item["col_id"],                 "centroid_x": item["centroid_x"],                 "centroid_y": item["centroid_y"],                 "master_area": item["master_area"],             })   def build_spatial_join_output():     """用精确空间关系建立 clip -> master 的一对一映射。"""     if arcpy.Exists(TEMP_SJ):         arcpy.management.Delete(TEMP_SJ)     if arcpy.Exists(MAPPING_FC):         arcpy.management.Delete(MAPPING_FC)      arcpy.analysis.SpatialJoin(         target_features=CLIP_FC,         join_features=MASTER_FC,         out_feature_class=TEMP_SJ,         join_operation="JOIN_ONE_TO_ONE",         join_type="KEEP_ALL",         match_option="INTERSECT",     )     arcpy.management.CopyFeatures(TEMP_SJ, MAPPING_FC)   def export_mapping_csv(master_info):     """导出干净的映射表，并生成边界字段。"""     fieldnames = [         "old_grid_id",         "new_grid_id",         "row_id",         "col_id",         "old_centroid_x",         "old_centroid_y",         "centroid_x",         "centroid_y",         "clip_area",         "master_area",         "cover_ratio",         "boundary_mask",         "valid_mask",         "offset_m",         "join_count",     ]      join_count_bad = 0     unmapped = 0     boundary_count = 0     max_offset = 0.0     total_rows = 0      with open(MAPPING_CSV, "w", newline="", encoding="utf-8-sig") as f:         writer = csv.DictWriter(f, fieldnames=fieldnames)         writer.writeheader()          cursor_fields = [             "grid_id",             "centroid_x",             "centroid_y",             "dl_grid_id",             "row_id",             "col_id",             "cent_x",             "crnt_y",             "Join_Count",             "SHAPE@AREA",         ]         with arcpy.da.SearchCursor(MAPPING_FC, cursor_fields) as cursor:             for old_grid_id, old_x, old_y, dl_grid_id, row_id, col_id, new_x, new_y, join_count, clip_area in cursor:                 total_rows += 1                  if join_count != 1:                     join_count_bad += 1                  if not dl_grid_id:                     unmapped += 1                     continue                  info = master_info[dl_grid_id]                 master_area = info["master_area"]                 cover_ratio = clip_area / master_area if master_area else 0.0                 cover_ratio = max(0.0, min(1.0, cover_ratio))                 boundary_mask = 1 if (cover_ratio > 0 and cover_ratio < 0.999999) else 0                 valid_mask = 1                 offset_m = ((old_x - new_x) ** 2 + (old_y - new_y) ** 2) ** 0.5                 max_offset = max(max_offset, offset_m)                 if boundary_mask == 1:                     boundary_count += 1                  writer.writerow({                     "old_grid_id": old_grid_id,                     "new_grid_id": dl_grid_id,                     "row_id": row_id,                     "col_id": col_id,                     "old_centroid_x": old_x,                     "old_centroid_y": old_y,                     "centroid_x": new_x,                     "centroid_y": new_y,                     "clip_area": clip_area,                     "master_area": master_area,                     "cover_ratio": round(cover_ratio, 6),                     "boundary_mask": boundary_mask,                     "valid_mask": valid_mask,                     "offset_m": round(offset_m, 6),                     "join_count": join_count,                 })      with open(REPORT_TXT, "w", encoding="utf-8") as f:         f.write("clip格网 -> 主格网 映射报告\n")         f.write("=" * 60 + "\n\n")         f.write(f"clip格网总数: {total_rows}\n")         f.write(f"未匹配数: {unmapped}\n")         f.write(f"Join_Count != 1 数量: {join_count_bad}\n")         f.write(f"边界格网数量(boundary_mask=1): {boundary_count}\n")         f.write(f"最大质心偏移距离: {max_offset:.6f} m\n\n")         f.write("字段说明：\n")         f.write("  old_grid_id  : 旧 clip 格网ID\n")         f.write("  new_grid_id  : 新主格网ID（RxxxCxxx）\n")         f.write("  cover_ratio  : clip格网面积 / 完整主格网面积\n")         f.write("  boundary_mask: 边界格网标记（0/1）\n")         f.write("  valid_mask   : 广州市内有效格网标记（clip映射到的均为1）\n")      if unmapped > 0 or join_count_bad > 0:         raise RuntimeError(             f"映射校验失败：未匹配 {unmapped} 个，Join_Count!=1 有 {join_count_bad} 个。"         )   def main():     OUTPUT_DIR.mkdir(parents=True, exist_ok=True)     ensure_output_gdb()      print("[1/4] 读取主格网元数据...")     master_info = load_master_info()     print(f"  主格网数量: {len(master_info)}")     export_master_metadata(master_info)     print(f"  已导出: {MASTER_META_CSV.name}")      print("\n[2/4] 执行 clip -> master 空间匹配...")     build_spatial_join_output()     print(f"  已输出映射要素类: {MAPPING_FC}")      print("\n[3/4] 导出干净映射表...")     export_mapping_csv(master_info)     print(f"  已导出: {MAPPING_CSV.name}")      print("\n[4/4] 完成")     print(f"  映射CSV : {MAPPING_CSV}")     print(f"  主格网表 : {MASTER_META_CSV}")     print(f"  质检报告 : {REPORT_TXT}")   if __name__ == "__main__":     main()
import arcpy  clip_fc = r"D:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\6、格网统一\Fishnet for spaceReaserch.gdb\grid_base_clip" master_fc = r"D:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\6、格网统一\DL-fishnet500m.gdb\grid_base_500m_dl_ready"  for fc in [clip_fc, master_fc]:     d = arcpy.Describe(fc)     print("FC:", fc)     print("SR Name:", d.spatialReference.name)     print("FactoryCode:", d.spatialReference.factoryCode)     print("Count:", int(arcpy.management.GetCount(fc)[0]))     print("-" * 50)
# -*- coding: utf-8 -*- """ ArcGIS：构建 clip 格网 -> 主格网（完整规则格网）映射表  设计目标： 1. 不推翻既有成果，不重做前 1-9 步实验 2. 将既有 clip 格网的随机 grid_id 丝滑替换到统一主格网体系 3. 一次性解决两个问题：    - 边界处 clip 后的非完整格网    - 广州市边界外的完整规则格网  核心原则： - 完整规则格网是唯一主格网（master grid） - clip 格网只是主格网在行政边界内的裁剪结果 - 每个 clip 格网都应精确对应到 1 个主格网单元 - 边界格网通过 cover_ratio / boundary_mask 表达，而不是继续保留不规则几何作为主键体系  在 ArcGIS Pro 的 Python 窗口中运行。 """  import arcpy import csv import os from pathlib import Path  arcpy.env.overwriteOutput = True  # ─── 路径配置 ────────────────────────────────────────────────── WORK_ROOT = Path(r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\6、格网统一")  CLIP_GDB = str(WORK_ROOT / "Fishnet for spaceReaserch.gdb") CLIP_FC = os.path.join(CLIP_GDB, "grid_base_clip")  MASTER_GDB = str(WORK_ROOT / "DL-fishnet500m.gdb") MASTER_FC = os.path.join(MASTER_GDB, "grid_base_500m_dl_ready")  OUTPUT_DIR = WORK_ROOT MAPPING_CSV = OUTPUT_DIR / "clip_to_master_grid_mapping.csv" MASTER_META_CSV = OUTPUT_DIR / "master_grid_metadata.csv" REPORT_TXT = OUTPUT_DIR / "clip_to_master_grid_mapping_report.txt"  GIS_OUTPUT_FOLDER = str(WORK_ROOT) GIS_OUTPUT_GDB = os.path.join(GIS_OUTPUT_FOLDER, "主格网统一.gdb") MAPPING_FC = os.path.join(GIS_OUTPUT_GDB, "clip_master_mapping") TEMP_SJ = r"in_memory\clip_master_spatial_join"  # ─── 工具函数 ────────────────────────────────────────────────── def find_existing_field(feature_class, candidates):     fields = {field.name.lower(): field.name for field in arcpy.ListFields(feature_class)}     for candidate in candidates:         if candidate.lower() in fields:             return fields[candidate.lower()]     raise RuntimeError(         f"在 {feature_class} 中找不到字段 {candidates}。现有字段: {sorted(fields.values())}"     )   def ensure_output_gdb():     if not os.path.exists(GIS_OUTPUT_FOLDER):         os.makedirs(GIS_OUTPUT_FOLDER)     if not arcpy.Exists(GIS_OUTPUT_GDB):         arcpy.management.CreateFileGDB(GIS_OUTPUT_FOLDER, os.path.basename(GIS_OUTPUT_GDB))   def load_master_info():     """读取主格网元数据，构建 grid_id -> info 字典。"""     master_info = {}     id_field = find_existing_field(MASTER_FC, ["dl_grid_id", "grid_id"])     row_field = find_existing_field(MASTER_FC, ["row_id"])     col_field = find_existing_field(MASTER_FC, ["col_id"])     fields = [id_field, row_field, col_field, "SHAPE@XY", "SHAPE@AREA"]     with arcpy.da.SearchCursor(MASTER_FC, fields) as cursor:         for dl_grid_id, row_id, col_id, shape_xy, shape_area in cursor:             cent_x, cent_y = shape_xy             master_info[dl_grid_id] = {                 "new_grid_id": dl_grid_id,                 "row_id": row_id,                 "col_id": col_id,                 "centroid_x": cent_x,                 "centroid_y": cent_y,                 "master_area": shape_area,             }     return master_info   def export_master_metadata(master_info):     """导出完整主格网元数据（全部格网，不仅仅是广州市内）。"""     fieldnames = [         "grid_id", "row_id", "col_id", "centroid_x", "centroid_y", "master_area"     ]     with open(MASTER_META_CSV, "w", newline="", encoding="utf-8-sig") as f:         writer = csv.DictWriter(f, fieldnames=fieldnames)         writer.writeheader()         for item in master_info.values():             writer.writerow({                 "grid_id": item["new_grid_id"],                 "row_id": item["row_id"],                 "col_id": item["col_id"],                 "centroid_x": item["centroid_x"],                 "centroid_y": item["centroid_y"],                 "master_area": item["master_area"],             })   def build_spatial_join_output():     """用精确空间关系建立 clip -> master 的一对一映射。"""     if arcpy.Exists(TEMP_SJ):         arcpy.management.Delete(TEMP_SJ)     if arcpy.Exists(MAPPING_FC):         arcpy.management.Delete(MAPPING_FC)      arcpy.analysis.SpatialJoin(         target_features=CLIP_FC,         join_features=MASTER_FC,         out_feature_class=TEMP_SJ,         join_operation="JOIN_ONE_TO_ONE",         join_type="KEEP_ALL",         match_option="WITHIN",     )     arcpy.management.CopyFeatures(TEMP_SJ, MAPPING_FC)   def export_mapping_csv(master_info):     """导出干净的映射表，并生成边界字段。"""     fieldnames = [         "old_grid_id",         "new_grid_id",         "row_id",         "col_id",         "old_centroid_x",         "old_centroid_y",         "centroid_x",         "centroid_y",         "clip_area",         "master_area",         "cover_ratio",         "boundary_mask",         "valid_mask",         "offset_m",         "join_count",     ]      join_count_bad = 0     unmapped = 0     boundary_count = 0     max_offset = 0.0     total_rows = 0      with open(MAPPING_CSV, "w", newline="", encoding="utf-8-sig") as f:         writer = csv.DictWriter(f, fieldnames=fieldnames)         writer.writeheader()          old_grid_id_field = find_existing_field(MAPPING_FC, ["grid_id"])         old_x_field = find_existing_field(MAPPING_FC, ["centroid_x", "cent_x"])         old_y_field = find_existing_field(MAPPING_FC, ["centroid_y", "cent_y", "crnt_y"])         new_grid_id_field = find_existing_field(MAPPING_FC, ["dl_grid_id"])         join_count_field = find_existing_field(MAPPING_FC, ["Join_Count"])          cursor_fields = [             old_grid_id_field,             old_x_field,             old_y_field,             new_grid_id_field,             join_count_field,             "SHAPE@AREA",         ]         with arcpy.da.SearchCursor(MAPPING_FC, cursor_fields) as cursor:             for old_grid_id, old_x, old_y, dl_grid_id, join_count, clip_area in cursor:                 total_rows += 1                  if join_count != 1:                     join_count_bad += 1                  if not dl_grid_id:                     unmapped += 1                     continue                  info = master_info[dl_grid_id]                 row_id = info["row_id"]                 col_id = info["col_id"]                 new_x = info["centroid_x"]                 new_y = info["centroid_y"]                 master_area = info["master_area"]                 cover_ratio = clip_area / master_area if master_area else 0.0                 cover_ratio = max(0.0, min(1.0, cover_ratio))                 boundary_mask = 1 if (cover_ratio > 0 and cover_ratio < 0.999999) else 0                 valid_mask = 1                 offset_m = ((old_x - new_x) ** 2 + (old_y - new_y) ** 2) ** 0.5                 max_offset = max(max_offset, offset_m)                 if boundary_mask == 1:                     boundary_count += 1                  writer.writerow({                     "old_grid_id": old_grid_id,                     "new_grid_id": dl_grid_id,                     "row_id": row_id,                     "col_id": col_id,                     "old_centroid_x": old_x,                     "old_centroid_y": old_y,                     "centroid_x": new_x,                     "centroid_y": new_y,                     "clip_area": clip_area,                     "master_area": master_area,                     "cover_ratio": round(cover_ratio, 6),                     "boundary_mask": boundary_mask,                     "valid_mask": valid_mask,                     "offset_m": round(offset_m, 6),                     "join_count": join_count,                 })      with open(REPORT_TXT, "w", encoding="utf-8") as f:         f.write("clip格网 -> 主格网 映射报告\n")         f.write("=" * 60 + "\n\n")         f.write(f"clip格网总数: {total_rows}\n")         f.write(f"未匹配数: {unmapped}\n")         f.write(f"Join_Count != 1 数量: {join_count_bad}\n")         f.write(f"边界格网数量(boundary_mask=1): {boundary_count}\n")         f.write(f"最大质心偏移距离: {max_offset:.6f} m\n\n")         f.write("字段说明：\n")         f.write("  old_grid_id  : 旧 clip 格网ID\n")         f.write("  new_grid_id  : 新主格网ID（RxxxCxxx）\n")         f.write("  cover_ratio  : clip格网面积 / 完整主格网面积\n")         f.write("  boundary_mask: 边界格网标记（0/1）\n")         f.write("  valid_mask   : 广州市内有效格网标记（clip映射到的均为1）\n")      if unmapped > 0 or join_count_bad > 0:         raise RuntimeError(             f"映射校验失败：未匹配 {unmapped} 个，Join_Count!=1 有 {join_count_bad} 个。"         )   def main():     OUTPUT_DIR.mkdir(parents=True, exist_ok=True)     ensure_output_gdb()      print("[1/4] 读取主格网元数据...")     master_info = load_master_info()     print(f"  主格网数量: {len(master_info)}")     export_master_metadata(master_info)     print(f"  已导出: {MASTER_META_CSV.name}")      print("\n[2/4] 执行 clip -> master 空间匹配...")     build_spatial_join_output()     print(f"  已输出映射要素类: {MAPPING_FC}")      print("\n[3/4] 导出干净映射表...")     export_mapping_csv(master_info)     print(f"  已导出: {MAPPING_CSV.name}")      print("\n[4/4] 完成")     print(f"  映射CSV : {MAPPING_CSV}")     print(f"  主格网表 : {MASTER_META_CSV}")     print(f"  质检报告 : {REPORT_TXT}")   if __name__ == "__main__":     main()
# -*- coding: utf-8 -*- """ ArcGIS：构建 clip 格网 -> 主格网（完整规则格网）映射表  设计目标： 1. 不推翻既有成果，不重做前 1-9 步实验 2. 将既有 clip 格网的随机 grid_id 丝滑替换到统一主格网体系 3. 一次性解决两个问题：    - 边界处 clip 后的非完整格网    - 广州市边界外的完整规则格网  核心原则： - 完整规则格网是唯一主格网（master grid） - clip 格网只是主格网在行政边界内的裁剪结果 - 每个 clip 格网都应精确对应到 1 个主格网单元 - 边界格网通过 cover_ratio / boundary_mask 表达，而不是继续保留不规则几何作为主键体系  在 ArcGIS Pro 的 Python 窗口中运行。 """  import arcpy import csv import os from pathlib import Path  arcpy.env.overwriteOutput = True  # ─── 路径配置 ────────────────────────────────────────────────── WORK_ROOT = Path(r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\6、格网统一")  CLIP_GDB = str(WORK_ROOT / "Fishnet for spaceReaserch.gdb") CLIP_FC = os.path.join(CLIP_GDB, "grid_base_clip")  MASTER_GDB = str(WORK_ROOT / "DL-fishnet500m.gdb") MASTER_FC = os.path.join(MASTER_GDB, "grid_base_500m_dl_ready")  OUTPUT_DIR = WORK_ROOT MAPPING_CSV = OUTPUT_DIR / "clip_to_master_grid_mapping.csv" MASTER_META_CSV = OUTPUT_DIR / "master_grid_metadata.csv" REPORT_TXT = OUTPUT_DIR / "clip_to_master_grid_mapping_report.txt"  GIS_OUTPUT_FOLDER = str(WORK_ROOT) GIS_OUTPUT_GDB = os.path.join(GIS_OUTPUT_FOLDER, "主格网统一.gdb") MAPPING_FC = os.path.join(GIS_OUTPUT_GDB, "clip_master_mapping") TEMP_SJ = r"in_memory\clip_master_spatial_join"  # ─── 工具函数 ────────────────────────────────────────────────── def find_existing_field(feature_class, candidates):     fields = {field.name.lower(): field.name for field in arcpy.ListFields(feature_class)}     for candidate in candidates:         if candidate.lower() in fields:             return fields[candidate.lower()]     raise RuntimeError(         f"在 {feature_class} 中找不到字段 {candidates}。现有字段: {sorted(fields.values())}"     )   def ensure_output_gdb():     if not os.path.exists(GIS_OUTPUT_FOLDER):         os.makedirs(GIS_OUTPUT_FOLDER)     if not arcpy.Exists(GIS_OUTPUT_GDB):         arcpy.management.CreateFileGDB(GIS_OUTPUT_FOLDER, os.path.basename(GIS_OUTPUT_GDB))   def load_master_info():     """读取主格网元数据，构建 grid_id -> info 字典。"""     master_info = {}     id_field = find_existing_field(MASTER_FC, ["dl_grid_id", "grid_id"])     row_field = find_existing_field(MASTER_FC, ["row_id"])     col_field = find_existing_field(MASTER_FC, ["col_id"])     fields = [id_field, row_field, col_field, "SHAPE@XY", "SHAPE@AREA"]     with arcpy.da.SearchCursor(MASTER_FC, fields) as cursor:         for dl_grid_id, row_id, col_id, shape_xy, shape_area in cursor:             cent_x, cent_y = shape_xy             master_info[dl_grid_id] = {                 "new_grid_id": dl_grid_id,                 "row_id": row_id,                 "col_id": col_id,                 "centroid_x": cent_x,                 "centroid_y": cent_y,                 "master_area": shape_area,             }     return master_info   def export_master_metadata(master_info):     """导出完整主格网元数据（全部格网，不仅仅是广州市内）。"""     fieldnames = [         "grid_id", "row_id", "col_id", "centroid_x", "centroid_y", "master_area"     ]     with open(MASTER_META_CSV, "w", newline="", encoding="utf-8-sig") as f:         writer = csv.DictWriter(f, fieldnames=fieldnames)         writer.writeheader()         for item in master_info.values():             writer.writerow({                 "grid_id": item["new_grid_id"],                 "row_id": item["row_id"],                 "col_id": item["col_id"],                 "centroid_x": item["centroid_x"],                 "centroid_y": item["centroid_y"],                 "master_area": item["master_area"],             })   def build_spatial_join_output():     """用精确空间关系建立 clip -> master 的一对一映射。"""     if arcpy.Exists(MAPPING_FC):         arcpy.management.Delete(MAPPING_FC)      try:         arcpy.analysis.SpatialJoin(             target_features=CLIP_FC,             join_features=MASTER_FC,             out_feature_class=MAPPING_FC,             join_operation="JOIN_ONE_TO_ONE",             join_type="KEEP_ALL",             match_option="HAVE_THEIR_CENTER_IN",         )     except arcpy.ExecuteError as exc:         raise RuntimeError(arcpy.GetMessages(2)) from exc      if not arcpy.Exists(MAPPING_FC):         raise RuntimeError("SpatialJoin 未生成输出要素类，请检查 ArcGIS 消息窗口。")   def export_mapping_csv(master_info):     """导出干净的映射表，并生成边界字段。"""     fieldnames = [         "old_grid_id",         "new_grid_id",         "row_id",         "col_id",         "old_centroid_x",         "old_centroid_y",         "centroid_x",         "centroid_y",         "clip_area",         "master_area",         "cover_ratio",         "boundary_mask",         "valid_mask",         "offset_m",         "join_count",     ]      join_count_bad = 0     unmapped = 0     boundary_count = 0     max_offset = 0.0     total_rows = 0      with open(MAPPING_CSV, "w", newline="", encoding="utf-8-sig") as f:         writer = csv.DictWriter(f, fieldnames=fieldnames)         writer.writeheader()          old_grid_id_field = find_existing_field(MAPPING_FC, ["grid_id"])         old_x_field = find_existing_field(MAPPING_FC, ["centroid_x", "cent_x"])         old_y_field = find_existing_field(MAPPING_FC, ["centroid_y", "cent_y", "crnt_y"])         new_grid_id_field = find_existing_field(MAPPING_FC, ["dl_grid_id"])         join_count_field = find_existing_field(MAPPING_FC, ["Join_Count"])          cursor_fields = [             old_grid_id_field,             old_x_field,             old_y_field,             new_grid_id_field,             join_count_field,             "SHAPE@AREA",         ]         with arcpy.da.SearchCursor(MAPPING_FC, cursor_fields) as cursor:             for old_grid_id, old_x, old_y, dl_grid_id, join_count, clip_area in cursor:                 total_rows += 1                  if join_count != 1:                     join_count_bad += 1                  if not dl_grid_id:                     unmapped += 1                     continue                  info = master_info[dl_grid_id]                 row_id = info["row_id"]                 col_id = info["col_id"]                 new_x = info["centroid_x"]                 new_y = info["centroid_y"]                 master_area = info["master_area"]                 cover_ratio = clip_area / master_area if master_area else 0.0                 cover_ratio = max(0.0, min(1.0, cover_ratio))                 boundary_mask = 1 if (cover_ratio > 0 and cover_ratio < 0.999999) else 0                 valid_mask = 1                 offset_m = ((old_x - new_x) ** 2 + (old_y - new_y) ** 2) ** 0.5                 max_offset = max(max_offset, offset_m)                 if boundary_mask == 1:                     boundary_count += 1                  writer.writerow({                     "old_grid_id": old_grid_id,                     "new_grid_id": dl_grid_id,                     "row_id": row_id,                     "col_id": col_id,                     "old_centroid_x": old_x,                     "old_centroid_y": old_y,                     "centroid_x": new_x,                     "centroid_y": new_y,                     "clip_area": clip_area,                     "master_area": master_area,                     "cover_ratio": round(cover_ratio, 6),                     "boundary_mask": boundary_mask,                     "valid_mask": valid_mask,                     "offset_m": round(offset_m, 6),                     "join_count": join_count,                 })      with open(REPORT_TXT, "w", encoding="utf-8") as f:         f.write("clip格网 -> 主格网 映射报告\n")         f.write("=" * 60 + "\n\n")         f.write(f"clip格网总数: {total_rows}\n")         f.write(f"未匹配数: {unmapped}\n")         f.write(f"Join_Count != 1 数量: {join_count_bad}\n")         f.write(f"边界格网数量(boundary_mask=1): {boundary_count}\n")         f.write(f"最大质心偏移距离: {max_offset:.6f} m\n\n")         f.write("字段说明：\n")         f.write("  old_grid_id  : 旧 clip 格网ID\n")         f.write("  new_grid_id  : 新主格网ID（RxxxCxxx）\n")         f.write("  cover_ratio  : clip格网面积 / 完整主格网面积\n")         f.write("  boundary_mask: 边界格网标记（0/1）\n")         f.write("  valid_mask   : 广州市内有效格网标记（clip映射到的均为1）\n")      if unmapped > 0 or join_count_bad > 0:         raise RuntimeError(             f"映射校验失败：未匹配 {unmapped} 个，Join_Count!=1 有 {join_count_bad} 个。"         )   def main():     OUTPUT_DIR.mkdir(parents=True, exist_ok=True)     ensure_output_gdb()      print("[1/4] 读取主格网元数据...")     master_info = load_master_info()     print(f"  主格网数量: {len(master_info)}")     export_master_metadata(master_info)     print(f"  已导出: {MASTER_META_CSV.name}")      print("\n[2/4] 执行 clip -> master 空间匹配...")     build_spatial_join_output()     print(f"  已输出映射要素类: {MAPPING_FC}")      print("\n[3/4] 导出干净映射表...")     export_mapping_csv(master_info)     print(f"  已导出: {MAPPING_CSV.name}")      print("\n[4/4] 完成")     print(f"  映射CSV : {MAPPING_CSV}")     print(f"  主格网表 : {MASTER_META_CSV}")     print(f"  质检报告 : {REPORT_TXT}")   if __name__ == "__main__":     main()
# -*- coding: utf-8 -*- """ ArcGIS：基于主格网标准年度CSV，批量重建年度要素类  作用： - 不改动你原来的 clip 年度图层，避免破坏历史成果 - 直接用主格网（完整规则格网）作为底图 - 将标准化后的年度 CSV 批量 Join 到主格网上 - 输出一套统一 ID 体系的新年度要素类  输出结果： - 广州市内有效格网图层（用于空间统计、影响因素分析） - 如有需要，可继续从完整主格网面板构建 ConvLSTM 输入张量  在 ArcGIS Pro 的 Python 窗口中运行。 """  import arcpy import os  arcpy.env.overwriteOutput = True  MASTER_GDB = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\6、格网统一\DL-fishnet500m.gdb" MASTER_FC = os.path.join(MASTER_GDB, "grid_base_500m_dl_ready")  CSV_DIR = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\6、格网统一\主格网统一输出\master_grid_yearly"  OUTPUT_FOLDER = r"d:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\6、格网统一" OUTPUT_GDB = os.path.join(OUTPUT_FOLDER, "主格网年度面板.gdb")   def find_existing_field(feature_class, candidates):     fields = {field.name.lower(): field.name for field in arcpy.ListFields(feature_class)}     for candidate in candidates:         if candidate.lower() in fields:             return fields[candidate.lower()]     raise RuntimeError(         f"在 {feature_class} 中找不到字段 {candidates}。现有字段: {sorted(fields.values())}"     )   def ensure_output_gdb():     if not os.path.exists(OUTPUT_FOLDER):         os.makedirs(OUTPUT_FOLDER)     if not arcpy.Exists(OUTPUT_GDB):         arcpy.management.CreateFileGDB(OUTPUT_FOLDER, os.path.basename(OUTPUT_GDB))   def main():     ensure_output_gdb()     master_join_field = find_existing_field(MASTER_FC, ["dl_grid_id", "grid_id"])      for year in range(2015, 2025):         csv_path = os.path.join(CSV_DIR, f"grid_panel_{year}.csv")         out_fc = os.path.join(OUTPUT_GDB, f"master_grid_panel_{year}")         layer_name = f"master_grid_layer_{year}"         table_name = f"master_panel_table_{year}"          if not os.path.exists(csv_path):             print(f"[跳过] {year}: 标准CSV不存在")             continue          if arcpy.Exists(out_fc):             arcpy.management.Delete(out_fc)          if arcpy.Exists(layer_name):             arcpy.management.Delete(layer_name)         if arcpy.Exists(table_name):             arcpy.management.Delete(table_name)          try:             arcpy.management.MakeFeatureLayer(MASTER_FC, layer_name)             arcpy.management.MakeTableView(csv_path, table_name)             arcpy.management.AddJoin(layer_name, master_join_field, table_name, "grid_id", "KEEP_COMMON")             arcpy.management.CopyFeatures(layer_name, out_fc)         except arcpy.ExecuteError as exc:             raise RuntimeError(f"{year} 年处理失败：\n{arcpy.GetMessages(2)}") from exc         finally:             if arcpy.Exists(layer_name):                 try:                     arcpy.management.RemoveJoin(layer_name)                 except Exception:                     pass                 arcpy.management.Delete(layer_name)             if arcpy.Exists(table_name):                 arcpy.management.Delete(table_name)          count = int(arcpy.management.GetCount(out_fc)[0])         print(f"[完成] {year}: {count} 个有效格网 -> {os.path.basename(out_fc)}")      print("\n=== 主格网年度图层全部完成 ===")     print(f"输出位置: {OUTPUT_GDB}")   if __name__ == "__main__":     main()
import os  # 你的文件夹路径 folder = r"D:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\7、最终格网标准数据\3、年度csv"  # 要添加的前缀 prefix = "master_"  # 遍历文件夹中的所有文件 for filename in os.listdir(folder):     if filename.lower().endswith(".csv"):         # 如果已经有此前缀，就跳过，避免重复添加         if not filename.startswith(prefix):             old_path = os.path.join(folder, filename)             new_name = prefix + filename             new_path = os.path.join(folder, new_name)              os.rename(old_path, new_path)             print(f"已重命名: {filename} -> {new_name}")  print("全部处理完成。")
import os  folder = r"D:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\7、最终格网标准数据\3、年度csv"  for filename in os.listdir(folder):     if filename.lower().endswith(".csv.xml"):         file_path = os.path.join(folder, filename)         os.remove(file_path)         print(f"已删除: {filename}")  print("删除完成。")
# -*- coding: utf-8 -*- """ 企业点位 CSV → GDB 批量转点（ArcGIS Pro 专用） - 输入：GIS 工程内 8、最终点位数据/ 下的全量 CSV + 10 个年度 CSV - 输出：8、最终点位数据/3、空间图层/企业点位.gdb/ - 坐标系：EPSG:4547 (CGCS2000 3-degree GK CM 114E) """ from pathlib import Path import time import arcpy  # ========== 路径 ========== ROOT = Path(r"D:\研究生\论文\高新技术企业空间集聚\GIS_new_experiment\阶段一：企业动态变量研究\8、最终点位数据")  CSV_FULL       = ROOT / "1、主格网对齐点位表" / "firm_year_points_2015_2024.csv" CSV_YEARLY_DIR = ROOT / "2、年度csv"  OUT_DIR = ROOT / "3、空间图层" GDB     = OUT_DIR / "企业点位.gdb"  # ========== 坐标系 ========== SR_GEO = arcpy.SpatialReference(4490)   # CGCS2000 Geographic（CSV 经纬度） SR_PRJ = arcpy.SpatialReference(4547)   # CGCS2000 3° GK CM 114E（投影）  # ========== 期望点数（用于自动校验，来自 step12 质控报告） ========== EXPECTED = {     "firm_year_points_all": 99498,     "firm_points_2015": 1865,  "firm_points_2016": 4643,  "firm_points_2017": 8514,     "firm_points_2018": 11479, "firm_points_2019": 11855, "firm_points_2020": 11369,     "firm_points_2021": 11239, "firm_points_2022": 12075, "firm_points_2023": 12936,     "firm_points_2024": 13523, }   def log(msg):     print(msg)     arcpy.AddMessage(msg)   def ensure_gdb():     """确保输出目录和 GDB 存在。"""     OUT_DIR.mkdir(parents=True, exist_ok=True)     if not arcpy.Exists(str(GDB)):         arcpy.management.CreateFileGDB(str(OUT_DIR), "企业点位.gdb")         log(f"新建 GDB: {GDB}")     else:         log(f"GDB 已存在: {GDB}")   def csv_to_point(csv_path: Path, fc_name: str) -> int:     """单个 CSV → 点要素（先 4490 建点，再 Project 到 4547）。"""     if not csv_path.exists():         raise FileNotFoundError(csv_path)      tmp_fc = str(GDB / f"{fc_name}__tmp4490")     out_fc = str(GDB / fc_name)      for fc in (tmp_fc, out_fc):         if arcpy.Exists(fc):             arcpy.management.Delete(fc)      # 1) XY Table To Point：按 EPSG:4490 地理坐标建临时点层     arcpy.management.XYTableToPoint(         in_table=str(csv_path),         out_feature_class=tmp_fc,         x_field="lon_cgcs",         y_field="lat_cgcs",         coordinate_system=SR_GEO,     )      # 2) Project：投影到 EPSG:4547     arcpy.management.Project(         in_dataset=tmp_fc,         out_dataset=out_fc,         out_coor_system=SR_PRJ,     )      # 3) 删除临时层     arcpy.management.Delete(tmp_fc)      cnt = int(arcpy.management.GetCount(out_fc)[0])     exp = EXPECTED.get(fc_name)     flag = "OK" if exp is None or cnt == exp else "!! 数量不符"     log(f"  {fc_name}: {cnt:,} 点  (期望 {exp:,})  {flag}")     return cnt   def main():     arcpy.env.overwriteOutput = True     t0 = time.time()      log("=" * 60)     log("企业点位 CSV → GDB 批量转换（输出到 ArcGIS 工程目录）")     log("=" * 60)      ensure_gdb()      log("\n[1/2] 全量点要素类 ...")     csv_to_point(CSV_FULL, "firm_year_points_all")      log("\n[2/2] 年度点要素类 ...")     for year in range(2015, 2025):         csv_to_point(CSV_YEARLY_DIR / f"firm_points_{year}.csv", f"firm_points_{year}")      log(f"\n耗时: {time.time() - t0:.1f} 秒")     log(f"输出位置: {GDB}")     log("坐标系: CGCS2000 3-degree GK CM 114E (EPSG:4547)")   main()
